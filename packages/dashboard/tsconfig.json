{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/client",
    "rootDir": "src",
    "composite": true
  },
  "include": ["src"],
  "exclude": ["src/server.ts"]
}
